package Airport;

import java.util.Scanner;

 public class AirportBookingSystem {

    static Scanner sc = new Scanner(System.in);


    static int[] ticketId = new int[100];
    static String[] passengerName = new String[100];
    static String[] fromCity = new String[100];
    static String[] toCity = new String[100];
    static int[] age = new int[100];
    static String[] flightClass = new String[100];
    static double[] ticketPrice = new double[100];

    static int count = 0;
    static int idCounter = 1001;

    public static void main(String[] args) {

        while (true) {
            System.out.println("\n===== AIRPORT TICKET BOOKING SYSTEM =====");
            System.out.println("1. Book Ticket");
            System.out.println("2. Cancel Ticket");
            System.out.println("3. View All Bookings");
            System.out.println("4. Search Ticket");
            System.out.println("5. Exit");
            System.out.print("Enter your choice: ");

            int choice = sc.nextInt();
            sc.nextLine(); 

            switch (choice) {
                case 1:
                    bookTicket();
                    break;
                case 2:
                    cancelTicket();
                    break;
                case 3:
                    viewAllBookings();
                    break;
                case 4:
                    searchTicket();
                    break;
                case 5:
                    System.out.println("Thank you for using Airport Booking System!");
                    System.exit(0);
                default:
                    System.out.println("Invalid Choice! Try again.");
            }
        }
    }

    // Book Ticket
    public static void bookTicket() {

        if (count >= 100) {
            System.out.println("Booking Full! Cannot book more tickets.");
            return;
        }

        System.out.println("\n--- BOOK TICKET ---");

        System.out.print("Enter Passenger Name: ");
        String name = sc.nextLine();

        System.out.print("Enter Age: ");
        int passengerAge = sc.nextInt();
        sc.nextLine();

        System.out.print("Enter From City: ");
        String from = sc.nextLine();

        System.out.print("Enter To City: ");
        String to = sc.nextLine();

        System.out.println("Select Class: ");
        System.out.println("1. Economy (₹3000)");
        System.out.println("2. Business (₹7000)");
        System.out.println("3. First Class (₹12000)");
        System.out.print("Enter choice: ");
        int classChoice = sc.nextInt();
        sc.nextLine();

        String cls = "";
        double price = 0;

        if (classChoice == 1) {
            cls = "Economy";
            price = 3000;
        } else if (classChoice == 2) {
            cls = "Business";
            price = 7000;
        } else if (classChoice == 3) {
            cls = "First Class";
            price = 12000;
        } else {
            System.out.println("Invalid Class Choice!");
            return;
        }

        // Store details
        ticketId[count] = idCounter;
        passengerName[count] = name;
        age[count] = passengerAge;
        fromCity[count] = from;
        toCity[count] = to;
        flightClass[count] = cls;
        ticketPrice[count] = price;

        System.out.println("\nTicket Booked Successfully!");
        System.out.println("Ticket ID: " + idCounter);
        System.out.println("Total Amount: ₹" + price);

        idCounter++;
        count++;
    }

    // Cancel Ticket
    public static void cancelTicket() {

        if (count == 0) {
            System.out.println("No bookings available to cancel.");
            return;
        }

        System.out.println("\n--- CANCEL TICKET ---");
        System.out.print("Enter Ticket ID to Cancel: ");
        int cancelId = sc.nextInt();

        int index = -1;

        for (int i = 0; i < count; i++) {
            if (ticketId[i] == cancelId) {
                index = i;
                break;
            }
        }

        if (index == -1) {
            System.out.println("Ticket ID Not Found!");
            return;
        }

        // Shift array elements to remove booking
        for (int i = index; i < count - 1; i++) {
            ticketId[i] = ticketId[i + 1];
            passengerName[i] = passengerName[i + 1];
            age[i] = age[i + 1];
            fromCity[i] = fromCity[i + 1];
            toCity[i] = toCity[i + 1];
            flightClass[i] = flightClass[i + 1];
            ticketPrice[i] = ticketPrice[i + 1];
        }

        count--;
        System.out.println("Ticket Cancelled Successfully!");
    }

    // View All Bookings
    public static void viewAllBookings() {

        if (count == 0) {
            System.out.println("No bookings available.");
            return;
        }

        System.out.println("\n--- ALL BOOKINGS ---");
        for (int i = 0; i < count; i++) {
            System.out.println("\nTicket ID: " + ticketId[i]);
            System.out.println("Passenger Name: " + passengerName[i]);
            System.out.println("Age: " + age[i]);
            System.out.println("From: " + fromCity[i]);
            System.out.println("To: " + toCity[i]);
            System.out.println("Class: " + flightClass[i]);
            System.out.println("Price: ₹" + ticketPrice[i]);
            System.out.println("-------------------------");
        }
    }

    // Search Ticket
    public static void searchTicket() {

        if (count == 0) {
            System.out.println("No bookings available.");
            return;
        }

        System.out.println("\n--- SEARCH TICKET ---");
        System.out.print("Enter Ticket ID to Search: ");
        int searchId = sc.nextInt();

        for (int i = 0; i < count; i++) {
            if (ticketId[i] == searchId) {
                System.out.println("\nTicket Found!");
                System.out.println("Ticket ID: " + ticketId[i]);
                System.out.println("Passenger Name: " + passengerName[i]);
                System.out.println("Age: " + age[i]);
                System.out.println("From: " + fromCity[i]);
                System.out.println("To: " + toCity[i]);
                System.out.println("Class: " + flightClass[i]);
                System.out.println("Price: ₹" + ticketPrice[i]);
                return;
            }
        }

        System.out.println("Ticket ID Not Found!");
    }
}
